{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "txture",
  "version": "0.1.0",
  "identifier": "com.heyo.txture",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build && rm -rf src-tauri/agent-bundle && mkdir -p src-tauri/agent-bundle && cp -r agent/dist agent/package.json src-tauri/agent-bundle/",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "txture",
        "width": 420,
        "height": 1152,
        "minWidth": 340,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "agent-bundle/"
    ]
  }
}
